# ============================================================
# ATB TAROT IA — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# NUNCA commite o .env.local no git
# ============================================================

# ------------------------------------------------------------
# SUPABASE
# Obtenha em: https://app.supabase.com → Settings → API
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Chave de serviço — SOMENTE no servidor, nunca no frontend
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ------------------------------------------------------------
# ANTHROPIC (Claude API)
# Obtenha em: https://console.anthropic.com → API Keys
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-...

# ------------------------------------------------------------
# Z-API (WhatsApp)
# Obtenha em: https://app.z-api.io → Instâncias
# ------------------------------------------------------------
ZAPI_INSTANCE_ID=seu-instance-id
ZAPI_TOKEN=seu-token-zapi
ZAPI_SECURITY_TOKEN=seu-security-token-cliente

# ------------------------------------------------------------
# KIWIFY WEBHOOK
# Na Kiwify: Configurações → Webhooks → adicionar URL:
#   https://seu-dominio.vercel.app/api/webhooks/kiwify
# O token é o valor que você define no campo "Token" da Kiwify.
# Ele será enviado no corpo do webhook (campo "token") e usado
# para validar a assinatura HMAC-SHA256 (campo "Signature").
# ------------------------------------------------------------
KIWIFY_WEBHOOK_TOKEN=seu-token-webhook-kiwify

# ------------------------------------------------------------
# UPSTASH REDIS (Rate Limiting)
# Obtenha em: https://console.upstash.com → Redis → Connect
# ------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxxxxxxxxxx

# ------------------------------------------------------------
# APP
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://seu-dominio.vercel.app
